# 部署配置模板：复制为 scripts/.deploy.env 后填写真实服务器信息

# 定义转发到 compose 的变量（空格分隔）
COMPOSE_VARS="IMAGE_NAME IMAGE_TAG APP_PORT CONTAINER_NAME"

# SSH 连接
SSH_HOST=your_server_ip
SSH_PORT=22
SSH_USER=root
SSH_KEY_PATH=
SSH_PASSWORD=

# 远程目录
REMOTE_DIR=/opt/rabc-go

# 镜像
IMAGE_NAME=rabc-go
IMAGE_TAG=
IMAGE_PLATFORM=linux/amd64
IMAGE_RETENTION_COUNT=5

# 容器
CONTAINER_NAME=rabc-go
COMPOSE_PROJECT_NAME=rabc-go
APP_PORT=8000
DOCKER_NETWORK=

# Compose 与应用环境文件
COMPOSE_FILE=deploy/docker-compose.yml
ENV_FILES=deploy/.env.production
